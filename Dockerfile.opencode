FROM node:24-bookworm-slim
ARG OPENCODE_VERSION
RUN test -n "$OPENCODE_VERSION" \
    && npm install --global "opencode-ai@${OPENCODE_VERSION}" \
    && opencode --version
RUN useradd --uid 10002 --create-home --shell /usr/sbin/nologin opencode \
    && mkdir -p /workspaces /opencode-config \
    && chown -R opencode:opencode /workspaces /opencode-config
USER opencode
WORKDIR /workspaces
EXPOSE 4096
CMD ["opencode", "serve", "--hostname", "0.0.0.0", "--port", "4096"]
