APP_BIND=0.0.0.0:8080
APP_BASE_URL=http://localhost:8080
DATABASE_URL=sqlite:///data/koda.db?mode=rwc
APP_SETUP_PASSWORD=change-me-before-production
APP_MASTER_KEY=replace-with-32-byte-base64-key
OPENCODE_BASE_URL=http://opencode:4096
OPENCODE_VERSION=1.0.0
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-opencode-password
MAX_CONCURRENT_SESSIONS=2
GITLAB_WEBHOOK_SECRET=change-gitlab-webhook-secret
EGRESS_PROXY_URL=
KODA_STATIC_DIR=/app/static
RUST_LOG=info,koda=debug
